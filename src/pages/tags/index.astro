---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTags } from '../../lib/posts';

const tags = getTags();
---

<BaseLayout title="标签">
  <section class="page-title">
    <h1>标签</h1>
    <p>按主题浏览文章。</p>
  </section>

  <div class="tag-cloud">
    {
      tags.map((tag) => (
        <a href={`/tags/${tag.slug}/`}>
          {tag.name}
          <span>{tag.count}</span>
        </a>
      ))
    }
  </div>
</BaseLayout>
